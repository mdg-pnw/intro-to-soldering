}
.pres-title {
  font-size: 1em;
  font-weight: 600;
  color: #f4a261;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

#soldering-icon {
  height:60px;
  padding-right:8px;
}

/* ── Persistent footer bar ── */
#pres-footer {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: 54px;
  background: #0d1526;
  border-top: 2px solid rgba(244,162,97,0.2);
  display: flex;
  align-items: center;
  padding: 0 80px;
  z-index: 1000;
  box-sizing: border-box;
}
#pres-footer select {
  background: #1a2a3d;
  color: #dce3f0;
  border: 1px solid rgba(244,162,97,0.45);
  padding: 6px 14px;
  border-radius: 4px;
  font-size: 0.9em;
  font-family: inherit;
  cursor: pointer;
  min-width: 260px;
}
#pres-footer select:focus { outline: none; border-color: #f4a261; }
#pres-footer tw-link, #viewer {
  background: transparent;
  color: #f4a261;
  border: 1px solid rgba(244,162,97,0.55);
  padding: 6px 14px;
  border-radius: 4px;
  font-size: 0.9em;
  font-family: inherit;
  cursor: pointer;
  margin-left: 8px;
  text-decoration: none;
}
#viewer {
  position: absolute;
  right: 80px;
}

/* ── Title slide ── */
.title-hero { padding-top: 70px; }
.subtitle   { font-size: 1.3em; color: #94a3b8; margin: 8px 0 36px; }
.presenter  { font-size: 0.9em;  color: #f4a261; }

/* ── End slide ── */
.end-center { text-align: center; padding-top: 50px; }
.end-center ul { display: inline-block; text-align: left; }

/* ── Component expand/collapse ── */
details.component {
  border: 1px solid rgba(244,162,97,0.25);
  border-radius: 6px;
  margin: 6px 0;
}
details.component summary {
  padding: 10px 16px;
  cursor: pointer;
  list-style: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 1.05em;
  background: rgba(255,255,255,0.03);
  border-radius: 6px;
  user-select: none;
}
details.component summary::-webkit-details-marker { display: none; }
details.component summary::marker { display: none; }
details.component summary:hover { background: rgba(244,162,97,0.1); }
details.component[open] > summary {
  border-bottom: 1px solid rgba(244,162,97,0.2);
  border-radius: 6px 6px 0 0;
  background: rgba(244,162,97,0.08);
}
.expand-icon {
  display: inline-block;
  transition: transform 0.2s ease;
  color: #f4a261;
  flex-shrink: 0;
  margin-left: 8px;
}
details.component[open] .expand-icon { transform: rotate(90deg); }
.component-body { padding: 12px 16px; line-height: 1.7; }
.component-body p { margin: 0.3em 0 0.6em; }
.component-body p:last-child { margin-bottom: 0; }

/* ── Video modal ── */
.video-btn {
  background: transparent;
  color: #f4a261;
  border: 1px solid rgba(244,162,97,0.55);
  padding: 8px 18px;
  border-radius: 4px;
  font-size: 1em;
  font-family: inherit;
  cursor: pointer;
  margin: 12px 0;
}
.video-btn:hover { background: #f4a261; color: #16213e; }

.video-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.82);
  z-index: 2000;
  align-items: center;
  justify-content: center;
}
.video-modal.open { display: flex; }
.video-modal-box {
  background: #0d1526;
  border: 1px solid rgba(244,162,97,0.4);
  border-radius: 8px;
  padding: 20px;
  max-width: 820px;
  width: 90%;
  position: relative;
}
.video-modal-close {
  position: absolute;
  top: 10px; right: 14px;
  background: transparent;
  border: none;
  color: #f4a261;
  font-size: 1.4em;
  cursor: pointer;
  line-height: 1;
}
.video-modal-close:hover { color: #fff; }
.video-modal-title {
  color: #e9c46a;
  font-size: 1em;
  font-weight: 600;
  margin-bottom: 14px;
  padding-right: 30px;
}
.video-wrapper {
  position: relative;
  padding-bottom: 56.25%; /* 16:9 */
  height: 0;
}
.video-wrapper iframe {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
}