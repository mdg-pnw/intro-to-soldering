  padding: 0 80px;
  z-index: 1000;
  box-sizing: border-box;
}
#slide-jump {
  background: #1a2a3d;
  color: #dce3f0;
  border: 1px solid rgba(244,162,97,0.45);
  padding: 6px 14px;
  border-radius: 4px;
  font-size: 0.9em;
  font-family: inherit;
  cursor: pointer;
  min-width: 260px;
}
#slide-jump:focus { outline: none; border-color: #f4a261; }
#slide-go {
  background: transparent;
  color: #f4a261;
  border: 1px solid rgba(244,162,97,0.55);
  padding: 6px 14px;
  border-radius: 4px;
  font-size: 0.9em;
  font-family: inherit;
  cursor: pointer;
  margin-left: 8px;
}
#slide-go:hover { background: #f4a261; color: #0d1526; }

/* ── Title slide ── */
.title-hero { padding-top: 70px; }
.subtitle   { font-size: 1.3em; color: #94a3b8; margin: 8px 0 36px; }
.presenter  { font-size: 0.9em;  color: #4a5a70; }

/* ── End slide ── */
.end-center { text-align: center; padding-top: 50px; }
.end-center ul { display: inline-block; text-align: left; }